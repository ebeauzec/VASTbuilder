# .gitignore for VAST Enterprise Architecture Tool

# OS-generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor/IDE directories
.vscode/
.idea/
*.swp
*.swo
*~
*.bak
*.tmp

# Node (if any tooling is added later)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build artifacts
dist/
build/
*.min.js
*.min.css

# Exported configs and documents (user data)
exports/
*.vast-config.json
vast-config-*.json

# Sensitive local config
.env
.env.local
.env.*.local

# Google Drive sync
*.gdoc
*.gsheet

# macOS quarantine
__MACOSX/
